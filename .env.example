# ── CosmicSec Platform — Environment Variables ─────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── JWT / Auth ─────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-256bit-random-hex-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://cosmicsec:changeme@postgres:5432/cosmicsec

# ── Redis ──────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── CORS ───────────────────────────────────────────────────────────────
COSMICSEC_CORS_ORIGINS=http://localhost:3000,http://localhost:4173

# ── External API Keys (leave blank if not using) ───────────────────────
SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=
OPENAI_API_KEY=

# ── Webhook / Integration URLs (leave blank if not using) ──────────────
SIEM_FORWARD_URL=
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
PAGERDUTY_EVENTS_URL=
JIRA_API_URL=
SERVICENOW_API_URL=
GITHUB_ISSUES_API_URL=

# ── Service Ports (override defaults) ─────────────────────────────────
AUTH_PORT=8001
SCAN_PORT=8002
RECON_PORT=8003
REPORT_PORT=8005
COLLAB_PORT=8006
NOTIFICATION_PORT=8012
EGRESS_PORT=8016
INTEGRATION_PORT=8020
BUGBOUNTY_PORT=8025
COMPLIANCE_PORT=8030
ORG_PORT=8035
SOC_PORT=8040
ADMIN_SSH_PORT=2222
AGENT_RELAY_PORT=8080
